import React, { useRef, useState, useEffect } from 'react';
import { View, Text, StyleSheet, Pressable, Animated, Image, SafeAreaView } from 'react-native';
import { GestureHandlerRootView, Gesture, GestureDetector } from 'react-native-gesture-handler';
import { tokens } from './src/styles/tokens';

const REMOTE_WASM_URL = 'https://kuber.studio/Nothing-DOOM-Essential-Backend/build/doom.wasm';

const b64chars = 'ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789+/';
function fastB64Encode(bytes: Uint8Array): string {
    let res = '';
    const len = bytes.length;
    const rem = len % 3;
    const max = len - rem;
    for (let i = 0; i < max; i += 3) {
        res += b64chars[bytes[i] >> 2] +
            b64chars[((bytes[i] & 3) << 4) | (bytes[i + 1] >> 4)] +
            b64chars[((bytes[i + 1] & 15) << 2) | (bytes[i + 2] >> 6)] +
            b64chars[bytes[i + 2] & 63];
    }
    if (rem === 1) {
        res += b64chars[bytes[max] >> 2] + b64chars[(bytes[max] & 3) << 4] + '==';
    } else if (rem === 2) {
        res += b64chars[bytes[max] >> 2] +
            b64chars[((bytes[max] & 3) << 4) | (bytes[max + 1] >> 4)] +
            b64chars[(bytes[max + 1] & 15) << 2] + '=';
    }
    return res;
}

function readModuleMemoryAsUtf8String(moduleMemory: any, offsetIntoMemory: number, stringByteLength: number) {
    const buffer8 = new Uint8Array(moduleMemory.buffer);
    const data = buffer8.slice(offsetIntoMemory, offsetIntoMemory + stringByteLength);
    let str = '';
    for (let i = 0; i < data.length; i++) {
        str += String.fromCharCode(data[i]);
    }
    return str;
}

const JOYSTICK_SIZE = 72;
const JOYSTICK_KNOB_SIZE = 28;
const JOYSTICK_RANGE = 20;

export default function App() {
    const [activeKeys, setActiveKeys] = useState<Set<string>>(new Set());
    const [doomFrameUri, setDoomFrameUri] = useState<string | null>(null);
    const [statusMessage, setStatusMessage] = useState<string>('STARTING...');
    const [devLogs, setDevLogs] = useState<string[]>([]);

    const addLog = (msg: string) => setDevLogs(prev => [...prev.slice(-9), msg]);

    const frameCountRef = useRef<number>(0);
    const joystickX = useRef(new Animated.Value(0)).current;
    const joystickY = useRef(new Animated.Value(0)).current;
    const activeDirections = useRef<Set<string>>(new Set());

    const doomInstanceRef = useRef<any>(null);
    const tickIntervalRef = useRef<any>(null);

    useEffect(() => {
        let isDestroyed = false;

        const WIDTH = 320;
        const HEIGHT = 200;
        const PIXEL_DATA_SIZE = WIDTH * HEIGHT * 4;
        const bmpBuffer = new Uint8Array(54 + PIXEL_DATA_SIZE);

        const bmpView = new DataView(bmpBuffer.buffer);
        bmpView.setUint16(0, 0x4D42, false);
        bmpView.setUint32(2, bmpBuffer.length, true);
        bmpView.setUint32(10, 54, true);
        bmpView.setUint32(14, 40, true);
        bmpView.setUint32(18, WIDTH, true);
        bmpView.setInt32(22, -HEIGHT, true);
        bmpView.setUint16(26, 1, true);
        bmpView.setUint16(28, 32, true);
        bmpView.setUint32(30, 0, true);

        let moduleInstanceMemory: any = null;

        const imports = {
            loading: {
                onGameInit: (width: number, height: number) => {
                    addLog(`Game Init: ${width}x${height}`);
                },
                wadSizes: () => { },
                readWads: () => { },
            },
            ui: {
                drawFrame: (indexOfFrameBuffer: number) => {
                    if (isDestroyed || !moduleInstanceMemory) return;
                    try {
                        if (frameCountRef.current === 0) addLog('DRAWN FIRST FRAME!');
                        if (frameCountRef.current === 35) addLog('DRAWN 35 FRAMES!');
                        frameCountRef.current++;

                        const doomPixels = new Uint8Array(moduleInstanceMemory.buffer, indexOfFrameBuffer, PIXEL_DATA_SIZE);
                        bmpBuffer.set(doomPixels, 54);
                        const base64Str = fastB64Encode(bmpBuffer);
                        setDoomFrameUri(`data:image/bmp;base64,${base64Str}`);
                    } catch (e: any) {
                        console.error(e);
                    }
                },
            },
            runtimeControl: {
                timeInMilliseconds: () => BigInt(Math.trunc(Date.now())),
            },
            console: {
                onInfoMessage: (messagePtr: number, length: number) => {
                    // addLog('[WASM] ' + readModuleMemoryAsUtf8String(moduleInstanceMemory, messagePtr, length));
                },
                onErrorMessage: (messagePtr: number, length: number) => {
                    addLog('[WASM ERR] ' + readModuleMemoryAsUtf8String(moduleInstanceMemory, messagePtr, length));
                },
            },
            gameSaving: {
                sizeOfSaveGame: () => 0,
                readSaveGame: () => 0,
                writeSaveGame: () => 0,
            },
        };

        async function initDoom() {
            try {
                addLog('1. Fetching URL...');
                setStatusMessage('DOWNLOADING ENGINE...');

                if (typeof WebAssembly === 'undefined') {
                    throw new Error('WebAssembly global object is UNDEFINED. Current Javascript engine (Hermes?) does not support compilation.');
                }

                const response = await fetch(REMOTE_WASM_URL);
                if (!response.ok) throw new Error(`HTTP ${response.status}`);

                addLog('2. Getting array buffer...');
                const wasmBytes = await response.arrayBuffer();
                addLog(`Buffer bytes: ${wasmBytes.byteLength}`);

                setStatusMessage('COMPILING WASM...');
                addLog('3. WebAssembly.instantiate()...');

                let instance;
                try {
                    const result = await WebAssembly.instantiate(wasmBytes, imports);
                    instance = result.instance;
                } catch (wasmErr: any) {
                    addLog('COMPILE ERR: ' + (wasmErr?.message || wasmErr));
                    setStatusMessage('WASM_FAIL');
                    return;
                }

                if (isDestroyed) return;
                addLog('4. Insta-success');

                moduleInstanceMemory = instance.exports.memory;
                doomInstanceRef.current = instance.exports;

                setTimeout(() => {
                    if (isDestroyed) return;
                    try {
                        addLog('5. Starting execution');
                        instance.exports.initGame();
                        tickIntervalRef.current = setInterval(instance.exports.tickGame, 1000 / 35);
                        setStatusMessage('');
                    } catch (err: any) {
                        addLog('CRASH: ' + (err.message || 'Unknown'));
                    }
                }, 150);

            } catch (err: any) {
                addLog(`FAIL: ${err?.message || err}`);
                setStatusMessage('DEAD');
            }
        }

        initDoom();

        return () => {
            isDestroyed = true;
            if (tickIntervalRef.current) clearInterval(tickIntervalRef.current);
        };
    }, []);

    const resolveDoomKey = (key: string) => {
        if (!doomInstanceRef.current) return null;
        const exports = doomInstanceRef.current;
        const map: Record<string, number> = {
            ArrowLeft: exports.KEY_LEFTARROW,
            ArrowRight: exports.KEY_RIGHTARROW,
            ArrowUp: exports.KEY_UPARROW,
            ArrowDown: exports.KEY_DOWNARROW,
            ',': exports.KEY_STRAFE_L,
            '.': exports.KEY_STRAFE_R,
            'Control': exports.KEY_FIRE,
            ' ': exports.KEY_USE,
            'Shift': exports.KEY_SHIFT,
            'Tab': exports.KEY_TAB,
            'Escape': exports.KEY_ESCAPE,
            'Enter': exports.KEY_ENTER,
            'Backspace': exports.KEY_BACKSPACE,
            'Alt': exports.KEY_ALT,
        };
        if (map[key] !== undefined) return map[key];
        if (key.length === 1) return key.charCodeAt(0);
        return null;
    };

    const keyDown = (key: string) => {
        if (activeKeys.has(key)) return;
        setActiveKeys(prev => new Set(prev).add(key));
        const doomKey = resolveDoomKey(key);
        if (doomKey !== null) doomInstanceRef.current?.reportKeyDown(doomKey);
    };

    const keyUp = (key: string) => {
        setActiveKeys(prev => {
            const next = new Set(prev);
            next.delete(key);
            return next;
        });
        const doomKey = resolveDoomKey(key);
        if (doomKey !== null) doomInstanceRef.current?.reportKeyUp(doomKey);
    };

    const joystickPan = Gesture.Pan()
        .runOnJS(true)
        .onUpdate((e) => {
            const clampedX = Math.max(-JOYSTICK_RANGE, Math.min(JOYSTICK_RANGE, e.translationX));
            const clampedY = Math.max(-JOYSTICK_RANGE, Math.min(JOYSTICK_RANGE, e.translationY));
            joystickX.setValue(clampedX);
            joystickY.setValue(clampedY);

            const threshold = 7;
            const newDirs = new Set<string>();

            if (clampedY < -threshold) newDirs.add('ArrowUp');
            if (clampedY > threshold) newDirs.add('ArrowDown');
            if (clampedX < -threshold) newDirs.add('ArrowLeft');
            if (clampedX > threshold) newDirs.add('ArrowRight');

            activeDirections.current.forEach(dir => {
                if (!newDirs.has(dir)) keyUp(dir);
            });
            newDirs.forEach(dir => {
                if (!activeDirections.current.has(dir)) keyDown(dir);
            });

            activeDirections.current = newDirs;
        })
        .onEnd(() => {
            Animated.spring(joystickX, { toValue: 0, useNativeDriver: false, tension: 120, friction: 10 }).start();
            Animated.spring(joystickY, { toValue: 0, useNativeDriver: false, tension: 120, friction: 10 }).start();
            activeDirections.current.forEach(dir => keyUp(dir));
            activeDirections.current.clear();
        });

    const ActionButton = ({ label, doomKey, flex, red }: { label: string; doomKey: string; flex?: number; red?: boolean; }) => (
        <Pressable
      style= {({ pressed }) => [
        styles.actionBtn,
        flex ? { flex } : {},
        (pressed || activeKeys.has(doomKey)) && (red ? styles.actionBtnActiveRed : styles.actionBtnActive),
    ]
}
onPressIn = {() => keyDown(doomKey)}
onPressOut = {() => keyUp(doomKey)}
    >
    <Text style={ styles.actionBtnText }> { label } </Text>
        </Pressable>
  );

return (
    <SafeAreaView style= {{ flex: 1, backgroundColor: '#000' }}>
        <GestureHandlerRootView style={ styles.root }>
            <View style={ styles.container }>

                {/* ── LEFT: Joystick + Strafe ── */ }
                < View style = { styles.leftPanel } >
                    <View style={ styles.strafeRow }>
                        <ActionButton label="◄" doomKey = "," />
                            <ActionButton label="►" doomKey = "." />
                                </View>

                                < GestureDetector gesture = { joystickPan } >
                                    <View style={ styles.joystickBase }>
                                    {
                                        [0, 1, 2, 3, 4].map(row => [0, 1, 2, 3, 4].map(col => (
                                            <View
                    key= {`${row}-${col}`}
style = { [styles.dot, row === 2 && col === 2 && styles.dotCenter]}
    />
                )))}
<Animated.View
                  style={
    [
        styles.joystickKnob,
        { transform: [{ translateX: joystickX }, { translateY: joystickY }] },
    ]
}
                />
    </View>
    </GestureDetector>

    < Text style = { styles.label } > MOVE </Text>
        </View>

{/* ── CENTER: Game / Logs ── */ }
<View style={ styles.gameContainer }>
    <View style={ styles.scanlines } pointerEvents = "none" />

    {
        doomFrameUri?(
              <Image
                source = {{ uri: doomFrameUri }}
style = { styles.webview }
resizeMode = "stretch"
fadeDuration = { 0}
    />
            ) : (
    <View style= {{ flex: 1, backgroundColor: '#111' }} />
            )}

{/* ALWAYS KEEP LOGS OVERLAY VISIBLE */ }
<View style={ { position: 'absolute', top: 10, left: 10, zIndex: 100 } } pointerEvents = "none" >
    <Text style={ { color: '#fff', fontSize: 13, fontWeight: 'bold', marginBottom: 5 } }> [WASM ENGINE STATUS] </Text>
{
    devLogs.map((log, i) => (
        <Text key= { i } style = {{ color: '#0f0', fontSize: 10, fontFamily: 'monospace', textShadowColor: '#000', textShadowOffset: { width: 1, height: 1 }, textShadowRadius: 1 }}> { '>'} { log } </Text>
              ))}
{ statusMessage ? <Text style={ { color: 'red', fontSize: 14, marginTop: 10, fontWeight: 'bold', textShadowColor: '#000', textShadowOffset: { width: 1, height: 1 }, textShadowRadius: 1 } }> !!{ statusMessage }!! </Text> : null }
</View>

    < View style = { styles.cornerTag } >
        <Text style={ styles.cornerTagText }> DOOM </Text>
            </View>
            </View>

{/* ── RIGHT: Action buttons ── */ }
<View style={ styles.rightPanel }>
    <ActionButton label="FIRE" doomKey = "Control" flex = { 1} red />
        <ActionButton label="USE" doomKey = " " flex = { 1} />
            <View style={ styles.smallBtnsRow }>
                <ActionButton label="ESC" doomKey = "Escape" />
                    <ActionButton label="↵" doomKey = "Enter" />
                        </View>
                        </View>

                        </View>
                        </GestureHandlerRootView>
                        </SafeAreaView>
  );
}

const styles = StyleSheet.create({
    root: {
        flex: 1,
    },
    container: {
        flex: 1,
        flexDirection: 'row',
        backgroundColor: tokens.colors.dark || '#1a1a1a',
        borderRadius: 22,
        overflow: 'hidden',
        padding: 10,
        gap: 8,
    },

    leftPanel: {
        width: 76,
        alignItems: 'center',
        justifyContent: 'flex-end',
        gap: 6,
        paddingBottom: 2,
    },
    strafeRow: {
        flexDirection: 'row',
        gap: 4,
    },
    joystickBase: {
        width: JOYSTICK_SIZE,
        height: JOYSTICK_SIZE,
        borderRadius: JOYSTICK_SIZE / 2,
        backgroundColor: tokens.colors['secondary-dark'] || '#333',
        justifyContent: 'center',
        alignItems: 'center',
        flexDirection: 'row',
        flexWrap: 'wrap',
        padding: 10,
        gap: 3,
    },
    dot: {
        width: 3,
        height: 3,
        borderRadius: 1.5,
        backgroundColor: tokens.colors['secondary-light'] || '#aaa',
        opacity: 0.35,
    },
    dotCenter: {
        backgroundColor: tokens.colors.light || '#fff',
        opacity: 0.7,
    },
    joystickKnob: {
        position: 'absolute',
        width: JOYSTICK_KNOB_SIZE,
        height: JOYSTICK_KNOB_SIZE,
        borderRadius: JOYSTICK_KNOB_SIZE / 2,
        backgroundColor: tokens.colors.light || '#fff',
        shadowColor: '#fff',
        shadowOpacity: 0.2,
        shadowRadius: 4,
    },
    label: {
        fontSize: 8,
        fontWeight: '700',
        color: tokens.colors['secondary-light'] || '#aaa',
        letterSpacing: 1.5,
        opacity: 0.5,
    },

    gameContainer: {
        flex: 1,
        borderRadius: 10,
        overflow: 'hidden',
        backgroundColor: '#000',
    },
    webview: {
        flex: 1,
        backgroundColor: '#000',
    },
    scanlines: {
        position: 'absolute',
        inset: 0,
        zIndex: 10,
        opacity: 0.04,
        backgroundColor: 'transparent',
        backgroundImage: 'repeating-linear-gradient(0deg, #000 0px, #000 1px, transparent 1px, transparent 2px)',
    },
    cornerTag: {
        position: 'absolute',
        top: 6,
        right: 6,
        zIndex: 20,
        backgroundColor: 'rgba(0,0,0,0.6)',
        paddingHorizontal: 5,
        paddingVertical: 2,
        borderRadius: 3,
        borderWidth: 1,
        borderColor: '#D81921',
    },
    cornerTagText: {
        color: '#D81921',
        fontSize: 7,
        fontWeight: '900',
        letterSpacing: 2,
    },

    rightPanel: {
        width: 62,
        gap: 5,
        justifyContent: 'flex-end',
        paddingBottom: 2,
    },
    actionBtn: {
        backgroundColor: tokens.colors['secondary-dark'] || '#333',
        borderRadius: 8,
        justifyContent: 'center',
        alignItems: 'center',
        paddingVertical: 6,
        paddingHorizontal: 4,
        minHeight: 28,
    },
    actionBtnActive: {
        backgroundColor: tokens.colors.light || '#fff',
    },
    actionBtnActiveRed: {
        backgroundColor: '#D81921',
    },
    actionBtnText: {
        color: tokens.colors.light || '#fff',
        fontSize: 9,
        fontWeight: '800',
        letterSpacing: 0.8,
    },
    smallBtnsRow: {
        flexDirection: 'row',
        gap: 4,
    },
});